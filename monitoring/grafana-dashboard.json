{
  "id": null,
  "uid": "ai-code-reviewer",
  "title": "AI Code Reviewer",
  "tags": [],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Gateway",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Gateway — Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"gateway\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Gateway — p99 Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"gateway\"}[1m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Gateway — Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"gateway\", status=~\"5..\"}[1m])",
          "legendFormat": "5xx errors"
